@page "{id:guid}"
@model Web.Pages.Productos.EliminarModel
@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1>Eliminar Producto</h1>

<div class="alert alert-danger">
    ¿Está seguro que desea eliminar este producto?
</div>

<div class="mb-3">
    <label class="form-label"><strong>Nombre</strong></label>
    <input class="form-control" value="@Model.Producto.Nombre" readonly />
</div>

<div class="mb-3">
    <label class="form-label"><strong>Descripción</strong></label>
    <input class="form-control" value="@Model.Producto.Descripcion" readonly />
</div>

<div class="mb-3">
    <label class="form-label"><strong>Precio</strong></label>
    <input class="form-control" value="@Model.Producto.Precio" readonly />
</div>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>