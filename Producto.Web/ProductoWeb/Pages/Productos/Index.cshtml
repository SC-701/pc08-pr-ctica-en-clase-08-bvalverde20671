@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<h1>Listado de Productos</h1>

<p>
    <a asp-page="Agregar" class="btn btn-primary">Agregar Producto</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Id SubCategoría</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Productos)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@item.Precio</td>
                <td>@item.IdSubCategoria</td>
                <td>
                    <a asp-page="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-page="Editar" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-page="Eliminar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>